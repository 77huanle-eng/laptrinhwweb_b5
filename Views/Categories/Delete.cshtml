@model Tuan3.Models.Category

@{
    ViewData["Title"] = "Xóa Danh Mục - " + Model.Name;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh mục</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Xóa danh mục</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger text-white p-4 text-center">
                    <i class="bi bi-exclamation-triangle display-3 mb-2 d-block"></i>
                    <h2 class="fw-bold mb-0">Bạn chắc chắn chứ?</h2>
                    <p class="text-white-50 mb-0">Bạn thực sự muốn xóa danh mục này khỏi cửa hàng?</p>
                </div>
                <div class="card-body p-4 text-center">
                    <h4 class="fw-bold text-dark mb-2">@Model.Name</h4>
                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-3 px-3 py-1.5 mb-4">
                        Chứa @(Model.Products?.Count ?? 0) sản phẩm
                    </span>

                    @if (Model.Products != null && Model.Products.Any())
                    {
                        <div class="alert alert-warning text-start mb-4" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            <strong>Cảnh báo:</strong> Việc xóa danh mục này sẽ khiến @Model.Products.Count sản phẩm không còn thuộc danh mục nào (các sản phẩm này sẽ không bị xóa).
                        </div>
                    }

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow">
                                <i class="bi bi-trash-fill me-2"></i>Xác nhận Xóa
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
