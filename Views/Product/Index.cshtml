@model IEnumerable<Tuan3.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-1">Sản phẩm</h1>
            <p class="text-muted">Quản lý kho hàng, chi tiết sản phẩm và giá bán.</p>
        </div>
        <a asp-action="Add" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4 hover-lift">
            <i class="bi bi-plus-lg me-2"></i>Thêm Sản phẩm
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase fs-7 fw-bold text-secondary border-bottom">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá bán</th>
                        <th>Danh mục</th>
                        <th>Mô tả</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-4 mb-3 d-block text-secondary"></i>
                                Không có sản phẩm nào. Hãy nhấn nút phía trên để thêm mới.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="ratio ratio-1x1 rounded-3 overflow-hidden border shadow-sm" style="width: 60px; height: 60px;">
                                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Name" class="object-fit-cover transition-transform" />
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center">
                                                <i class="bi bi-image text-muted fs-4"></i>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-semibold text-dark fs-6">@product.Name</span>
                                </td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle fs-6 px-3 py-2 rounded-pill">
                                        @product.Price.ToString("#,##0") đ
                                    </span>
                                </td>
                                <td>
                                    @if (product.Category != null)
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-3 px-2 py-1.5">
                                            @product.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fs-7">Chưa phân loại</span>
                                    }
                                </td>
                                <td>
                                    <p class="text-truncate mb-0" style="max-width: 250px;" title="@product.Description">
                                        @product.Description
                                    </p>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group gap-1">
                                        <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-secondary btn-sm rounded-pill px-3" title="Chi tiết">
                                            <i class="bi bi-eye"></i> Xem
                                        </a>
                                        <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm rounded-pill px-3" title="Xóa">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
