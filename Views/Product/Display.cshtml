@model Tuan3.Models.Product

@{
    ViewData["Title"] = Model.Name + " - Chi tiết sản phẩm";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-white">
        <div class="row g-0">
            <!-- Product Image Section -->
            <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-4" style="min-height: 400px;">
                <div class="ratio ratio-4x3 rounded-4 overflow-hidden shadow border bg-white max-w-100" style="max-width: 500px;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="object-fit-contain" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light">
                            <i class="bi bi-image text-muted display-1"></i>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Specs Section -->
            <div class="col-md-6 p-5 d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        @if (Model.Category != null)
                        {
                            <span class="badge bg-primary px-3 py-2 rounded-pill fs-7 text-uppercase">
                                @Model.Category.Name
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary px-3 py-2 rounded-pill fs-7 text-uppercase">
                                Chưa phân loại
                            </span>
                        }
                    </div>

                    <h1 class="display-5 fw-bold text-dark mb-3">@Model.Name</h1>

                    <h2 class="text-success fw-extrabold mb-4 display-6">
                        @Model.Price.ToString("#,##0") đ
                    </h2>

                    <hr class="my-4 text-muted opacity-25" />

                    <h5 class="fw-bold text-secondary mb-3">Mô tả sản phẩm</h5>
                    <p class="text-muted leading-relaxed fs-5 mb-4" style="white-space: pre-line;">
                        @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả cho sản phẩm này." : Model.Description)
                    </p>
                </div>

                <div class="mt-4">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="input-group" style="width: 130px;">
                            <span class="input-group-text bg-white border-end-0">SL:</span>
                            <input type="number" name="quantity" class="form-control border-start-0 ps-0" value="1" min="1" max="100">
                        </div>
                        <button type="submit" class="btn btn-success btn-lg rounded-pill px-4 flex-grow-1 shadow">
                            <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ
                        </button>
                    </form>
                </div>

                <div class="d-flex gap-2 pt-3">
                    @if (User.IsInRole(SD.Role_Admin))
                    {
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
                            <i class="bi bi-pencil me-2"></i>Chỉnh sửa sản phẩm
                        </a>
                    }
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
